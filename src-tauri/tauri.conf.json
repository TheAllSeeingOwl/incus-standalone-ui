{
  "productName": "Incus Manager",
  "version": "0.1.0",
  "identifier": "app.incus.manager",
  "build": {
    "beforeBuildCommand": "bash scripts/build-docs.sh && yarn --cwd incus-ui-canonical install --frozen-lockfile && yarn --cwd incus-ui-canonical build && yarn build",
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
